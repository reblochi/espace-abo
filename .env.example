# Base de donnees
DATABASE_URL="postgresql://user:password@localhost:5432/espace_abo?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Stripe (PSP par defaut)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRODUCT_ID="prod_..."
STRIPE_SUBSCRIPTION_PRICE_ID="price_..."

# HiPay (PSP alternatif)
HIPAY_ENVIRONMENT="stage"
HIPAY_API_USERNAME="your-username"
HIPAY_API_PASSWORD="your-password"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (Emails)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@votredomaine.com"

# API Advercity (backend Symfony)
# Local: http://localhost:8080 (docker-compose)
# Token JWT: POST {ADVERCITY_API_URL}/api/v1/login {"username":"...","password":"..."}
ADVERCITY_API_URL="http://localhost:8080"
ADVERCITY_API_TOKEN=""

# Fenige PayTool (hosted payment page)
FENIGE_API_KEY="your-api-key"
FENIGE_MERCHANT_UUID="your-merchant-uuid"
FENIGE_BASIC_AUTH_USER="your-username"
FENIGE_BASIC_AUTH_PASSWORD="your-password"
FENIGE_WEBHOOK_SECRET="your-webhook-secret-token"
FENIGE_SANDBOX="true"
# FENIGE_PRODUCTION_API_URL="https://paytool-api.fenige.pl"
# FENIGE_PRODUCTION_PAGE_URL="https://paytool.fenige.pl"

# PSP Actif (stripe, hipay ou fenige)
ACTIVE_PSP="stripe"
