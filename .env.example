# Base de donnees
DATABASE_URL="postgresql://user:password@localhost:5432/espace_abo?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Stripe (PSP par defaut)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRODUCT_ID="prod_..."
STRIPE_SUBSCRIPTION_PRICE_ID="price_..."

# HiPay (PSP alternatif)
HIPAY_ENVIRONMENT="stage"
HIPAY_API_USERNAME="your-username"
HIPAY_API_PASSWORD="your-password"

# Cloudflare R2 / S3
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET="your-bucket"
S3_REGION="auto"
S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"

# Resend (Emails)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@votredomaine.com"

# API Advercity (backend Symfony)
# Local: http://localhost:8080 (docker-compose)
# Token JWT: POST {ADVERCITY_API_URL}/api/v1/login {"username":"...","password":"..."}
ADVERCITY_API_URL="http://localhost:8080"
ADVERCITY_API_TOKEN=""

# PSP Actif (stripe ou hipay)
ACTIVE_PSP="stripe"
